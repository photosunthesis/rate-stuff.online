{
  "name": "rate_stuff_online",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000",
    "dev:wrangler": "wrangler dev",
    "build": "vite build && cp instrument.server.mjs dist/server",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "auth:secret": "pnpm dlx @better-auth/cli@latest secret",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config ./src/lib/auth/auth.ts -y --output ./src/infrastructure/db/schema/auth.ts",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "start": "node --import ./dist/server/instrument.server.mjs dist/server/index.js"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.41.0",
    "@danielgtmn/umami-react": "^1.1.6",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@imagekit/react": "^5.0.2",
    "@sentry/tanstackstart-react": "^10.58.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/router-plugin": "^1.168.18",
    "better-auth": "^1.6.19",
    "dompurify": "^3.4.11",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "postgres": "^3.4.9",
    "quill": "^2.0.3",
    "quill-delta-to-html": "^0.12.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0",
    "react-intersection-observer": "^10.0.3",
    "resend": "^6.14.0",
    "tailwindcss": "^4.3.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
