{
  "name": "rate_stuff_online",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000",
    "dev:wrangler": "wrangler dev",
    "build": "vite build && cp instrument.server.mjs dist/server",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "auth:secret": "pnpm dlx @better-auth/cli@latest secret",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config ./src/lib/auth/auth.ts -y --output ./src/db/schema/auth.ts",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "start": "node --import ./dist/server/instrument.server.mjs dist/server/index.js"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.0",
    "@danielgtmn/umami-react": "^1.1.6",
    "@imagekit/nodejs": "^7.3.0",
    "@imagekit/react": "^5.0.2",
    "@sentry/tanstackstart-react": "^10.42.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.9.6",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-router-devtools": "^1.163.3",
    "@tanstack/react-router-ssr-query": "^1.163.3",
    "@tanstack/react-start": "^1.166.1",
    "@tanstack/router-plugin": "^1.164.0",
    "better-auth": "^1.5.2",
    "dompurify": "^3.3.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.576.0",
    "marked": "^17.0.3",
    "postgres": "^3.4.8",
    "quill": "^2.0.3",
    "quill-delta-to-html": "^0.12.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-intersection-observer": "^10.0.3",
    "resend": "^6.9.3",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tanstack/devtools-vite": "^0.5.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/quill": "^2.0.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-seed": "^0.3.1",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.70.0"
  }
